# Greyhound Agent - Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# GRV FastTrack API key (official Australian greyhound race data)
# Register at: https://fasttrack.grv.org.au
FAST_TRACK_API_KEY=your_fasttrack_key_here

# Anthropic API key (for Claude AI agent features)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# TAB API key (optional - for TAB race/results data)
# Leave as placeholder if not using TAB API
TAB_API_KEY=your_tab_api_key_here

# SQLite database path (relative to repo root)
DB_PATH=data/greyhound.db
